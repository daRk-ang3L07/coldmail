# --- Server ---
PORT=4000
# Used to sign the session cookie. Set to any long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google OAuth (from Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must EXACTLY match an "Authorized redirect URI" in your OAuth client.
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# --- Frontend ---
# Where to redirect after OAuth. For the React dev server, set this to the Vite
# origin. Leave blank in production (Express serves the built frontend itself).
FRONTEND_URL=http://localhost:5173

# --- Production (set these on the server; leave defaults for local dev) ---
# NODE_ENV=production            # enables secure cookies + serves the built frontend
# DATA_DIR=/data                 # persistent volume path for SQLite + tokens
# In production, GOOGLE_REDIRECT_URI + FRONTEND_URL use your real HTTPS domain, e.g.:
#   GOOGLE_REDIRECT_URI=https://yourname.duckdns.org/auth/google/callback
#   FRONTEND_URL=                # blank — same origin as the API
